# ── Firebase (Frontend) ──────────────────────────────────────────
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ── Backend URL (Frontend) ───────────────────────────────────────
VITE_API_URL=https://your-backend.railway.app/api

# ── Payments (Frontend) ─────────────────────────────────────────
VITE_STRIPE_PUBLIC_KEY=pk_live_...          # optional — shows "Coming Soon" if absent
VITE_KASHIER_MERCHANT_ID=                   # Kashier merchant ID (Egyptian payments)

# ── Support Email (Frontend) ─────────────────────────────────────
VITE_SUPPORT_EMAIL=support@corvus.io

# ── Backend (Railway env vars) ───────────────────────────────────
SECRET_KEY=change-me-in-production
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
REDIS_URL=redis://...                       # required in production for rate limiting
STRIPE_SECRET_KEY=sk_live_...              # optional
KASHIER_MERCHANT_ID=                       # Kashier merchant ID
KASHIER_API_KEY=                           # Kashier API key (secret)
KASHIER_MODE=live                          # "test" or "live"
SENDGRID_API_KEY=                          # email notifications
SMTP_USER=                                 # SMTP fallback
SMTP_PASS=

# ── Local AI (Backend, optional) ────────────────────────────────
OLLAMA_URL=http://localhost:11434           # optional self-hosted LLM
LOCAL_LLM_MODEL=qwen2.5:3b
