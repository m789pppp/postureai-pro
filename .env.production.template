##############################################################
# PostureAI Pro — Production Environment Variables
# ⚠️  NEVER commit this file with real values to git
# Copy to .env.local (frontend) and .env (backend) and fill in
##############################################################

# ══════════════════════════════════════════════════════════════
# FRONTEND (.env.local)  — VITE_ prefix required
# ══════════════════════════════════════════════════════════════

# ── Firebase ───────────────────────────────────────────────────
# Get from: Firebase Console → Project Settings → General → Your apps
VITE_FIREBASE_API_KEY=AIza...
VITE_FIREBASE_AUTH_DOMAIN=postureai-prod.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=postureai-prod
VITE_FIREBASE_STORAGE_BUCKET=postureai-prod.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abc123

# ── Backend API ────────────────────────────────────────────────
# Railway production URL
VITE_API_URL=https://postureai-backend.railway.app/api

# ── Stripe (public key — safe to expose) ──────────────────────
# Get from: https://dashboard.stripe.com/apikeys
VITE_STRIPE_PUBLIC_KEY=pk_live_...

# Stripe Price IDs
# Get from: https://dashboard.stripe.com/products
VITE_STRIPE_PRICE_PRO_MONTHLY=price_...
VITE_STRIPE_PRICE_PRO_YEARLY=price_...
VITE_STRIPE_PRICE_BUSINESS_MONTHLY=price_...
VITE_STRIPE_PRICE_BUSINESS_YEARLY=price_...

# ── PayMob (MENA payments) ─────────────────────────────────────
# Get from: https://accept.paymob.com/portal2/en/settings
VITE_PAYMOB_PUBLIC_KEY=egy_pk_...
VITE_PAYMOB_IFRAME_ID=your_iframe_id

# ── Monitoring ────────────────────────────────────────────────
# Sentry: https://sentry.io → New Project → React
VITE_SENTRY_DSN=https://...@sentry.io/...

# PostHog: https://app.posthog.com → Project Settings → API Keys
VITE_POSTHOG_KEY=phc_...
VITE_POSTHOG_HOST=https://app.posthog.com

# ── Branding ──────────────────────────────────────────────────
VITE_APP_NAME=PostureAI Pro
VITE_SUPPORT_EMAIL=support@postureai.io
VITE_ADMIN_PHONE=+20 100 000 0000
VITE_CALENDLY_URL=https://calendly.com/postureai/demo

# Auto-approve domain (employees from this domain get elite tier automatically)
# Leave empty if not needed
VITE_AUTO_APPROVE_DOMAIN=

# ══════════════════════════════════════════════════════════════
# BACKEND (.env)
# ══════════════════════════════════════════════════════════════

# ── App ────────────────────────────────────────────────────────
FLASK_ENV=production
PORT=5050
SECRET_KEY=generate-with-python-secrets-token-hex-32

# CRITICAL: Must match your Vercel/custom domain
APP_URL=https://postureai.io
ALLOWED_ORIGINS=https://postureai.io,https://www.postureai.io,https://postureai.vercel.app

# ── Supabase (PostgreSQL) ──────────────────────────────────────
# Get from: https://supabase.com → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJhb...
SUPABASE_SERVICE_ROLE_KEY=eyJhb...  # NEVER expose to frontend
# Get connection string from: Supabase → Settings → Database → Connection string
SUPABASE_DB_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# ── Firebase Admin ─────────────────────────────────────────────
# Get from: Firebase Console → Project Settings → Service Accounts → Generate key
# Paste the entire JSON as one line (or use file path):
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"..."}
# Alternative: path to file
# FIREBASE_SERVICE_ACCOUNT_FILE=/app/firebase-service-account.json

# ── Gemini AI ──────────────────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...

# ── Stripe (secret key — backend only) ────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Run: stripe listen --forward-to localhost:5050/api/stripe/webhook
# Then use the webhook secret printed

STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_YEARLY=price_...
STRIPE_PRICE_BUSINESS_MONTHLY=price_...
STRIPE_PRICE_BUSINESS_YEARLY=price_...

# ── PayMob ────────────────────────────────────────────────────
PAYMOB_SECRET_KEY=...
PAYMOB_PUBLIC_KEY=egy_pk_...
PAYMOB_HMAC_SECRET=...
PAYMOB_INTEGRATION_CARD=...
PAYMOB_INTEGRATION_WALLET=...
PAYMOB_IFRAME_ID=...

# ── Email (Resend — recommended) ──────────────────────────────
# Get from: https://resend.com → API Keys
RESEND_API_KEY=re_...
FROM_EMAIL=PostureAI Pro <noreply@postureai.io>
SUPPORT_EMAIL=support@postureai.io
ADMIN_EMAIL=admin@postureai.io

# Fallback SMTP (only used if Resend fails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password

# ── Redis ─────────────────────────────────────────────────────
# Railway Redis addon or Upstash (https://upstash.com)
REDIS_URL=redis://default:password@your-redis.railway.app:6379
CELERY_BROKER_URL=redis://default:password@your-redis.railway.app:6379/1
CELERY_RESULT_BACKEND=redis://default:password@your-redis.railway.app:6379/2

# ── Monitoring ────────────────────────────────────────────────
SENTRY_DSN=https://...@sentry.io/...

# ── Admin ─────────────────────────────────────────────────────
ADMIN_PHONE=+20 100 000 0000
WORK_HOURS_START=9
WORK_HOURS_END=18

# ── Integrations ──────────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/...
WA_PHONE_NUMBER_ID=
WA_ACCESS_TOKEN=

# ── WebSockets ────────────────────────────────────────────────
SOCKETIO_ENABLED=false  # Set true to enable real-time

##############################################################
# SETUP INSTRUCTIONS
##############################################################
#
# 1. Firebase:
#    a) Go to https://console.firebase.google.com
#    b) Create project "postureai-prod"
#    c) Enable Authentication → Email/Password + Google
#    d) Enable Firestore Database
#    e) Frontend: Get web app config from Project Settings → General
#    f) Backend: Generate service account from Project Settings → Service Accounts
#
# 2. Supabase:
#    a) Go to https://supabase.com, create project
#    b) Run schema.sql in SQL Editor
#    c) Copy URL + keys from Project Settings → API
#
# 3. Stripe:
#    a) Go to https://dashboard.stripe.com
#    b) Create products: Professional ($9/mo, $7/yr), Business ($19/mo, $15/yr)
#    c) Copy price IDs to env
#    d) Set webhook: https://your-backend.railway.app/api/stripe/webhook
#       Events: checkout.session.completed, customer.subscription.*, invoice.*
#
# 4. Resend:
#    a) Go to https://resend.com, create account
#    b) Add and verify your domain (postureai.io)
#    c) Create API key with send access
#
# 5. Railway (backend):
#    a) Go to https://railway.app
#    b) New project → Deploy from GitHub repo
#    c) Add all backend env vars in the Variables tab
#    d) Add Redis service
#
# 6. Vercel (frontend):
#    a) Import GitHub repo at https://vercel.com
#    b) Set root directory to "frontend"
#    c) Add all VITE_ env vars
#    d) Deploy
#
# 7. Sentry (optional but recommended):
#    a) https://sentry.io → Create React + Python projects
#    b) Copy DSNs to frontend and backend
#
# 8. PostHog (analytics):
#    a) https://app.posthog.com → Create project
#    b) Copy project API key to VITE_POSTHOG_KEY
##############################################################


# ── WorkOS SSO (v13 merge) ─────────────────────────────────────────
WORKOS_API_KEY=
WORKOS_CLIENT_ID=

# ── Custom Domains / White-label (v13 merge) ───────────────────────
VERCEL_TOKEN=
VERCEL_PROJECT_ID=
VERCEL_TEAM_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
