# PostureAI Pro — Frontend Environment Variables
# Copy to .env.local — NEVER commit this file to git

# ── Firebase (required) ────────────────────────────────────────────
# Get from: Firebase Console → Project Settings → Your apps
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef

# ── Backend URL (required) ─────────────────────────────────────────
# Local dev: http://localhost:5050/api
# Production: https://your-backend.railway.app/api
VITE_API_URL=http://localhost:5050/api

# ── PayMob — Egypt payments (required for billing) ─────────────────
# Get from: https://accept.paymob.com/portal2/en/settings
VITE_PAYMOB_IFRAME_ID=your_iframe_id
VITE_PAYMOB_PUBLIC_KEY=your_public_key

# ── Stripe — International payments (optional) ─────────────────────
# Get from: https://dashboard.stripe.com/apikeys
VITE_STRIPE_PUBLIC_KEY=pk_live_...
VITE_STRIPE_PRICE_PRO_MONTHLY=price_...
VITE_STRIPE_PRICE_PRO_YEARLY=price_...
VITE_STRIPE_PRICE_ELITE_MONTHLY=price_...
VITE_STRIPE_PRICE_ELITE_YEARLY=price_...

# ── App Config (required) ──────────────────────────────────────────
VITE_ADMIN_EMAIL=admin@yourcompany.com
VITE_SUPPORT_EMAIL=support@yourcompany.com
VITE_ADMIN_PHONE=+201XXXXXXXXX
# Domain that gets auto-approved to Elite tier (e.g. your company domain)
VITE_AUTO_APPROVE_DOMAIN=yourcompany.com

# ── SSO (Enterprise tier only) ─────────────────────────────────────
# Configure in Firebase Console → Authentication → Sign-in providers → SAML
VITE_SAML_AZURE_PROVIDER_ID=saml.azure-ad
VITE_SAML_OKTA_PROVIDER_ID=saml.okta

# ── Monitoring (optional but recommended) ──────────────────────────
# Get from: https://sentry.io → Settings → Projects → Client Keys
VITE_SENTRY_DSN=https://xxx@sentry.io/project-id
