# ============================================================
# PostureAI Pro — Frontend Environment Variables
# Copy this file to .env.local for local development
# Add ALL of these to Vercel → Project Settings → Environment Variables
# ============================================================

# ── FIREBASE (REQUIRED) ──────────────────────────────────────
# Get from: console.firebase.google.com → Your Project → Project Settings → General → Your Apps → Web App
VITE_FIREBASE_API_KEY=AIzaSy...
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abc123

# ── BACKEND URL (REQUIRED) ───────────────────────────────────
# Your Railway/Render backend URL
VITE_API_URL=https://your-backend.railway.app/api

# ── STRIPE (REQUIRED for payments) ───────────────────────────
# Get from: dashboard.stripe.com → Developers → API Keys
VITE_STRIPE_PUBLIC_KEY=pk_live_...

# Get from: Stripe Dashboard → Products → Create these 6 products first
VITE_STRIPE_PRICE_STANDARD_MONTHLY=price_...
VITE_STRIPE_PRICE_STANDARD_YEARLY=price_...
VITE_STRIPE_PRICE_PRO_MONTHLY=price_...
VITE_STRIPE_PRICE_PRO_YEARLY=price_...
VITE_STRIPE_PRICE_ELITE_MONTHLY=price_...
VITE_STRIPE_PRICE_ELITE_YEARLY=price_...

# ── PAYMOB (REQUIRED for Egypt payments) ─────────────────────
# Get from: accept.paymob.com → Settings → Account Info
VITE_PAYMOB_PUBLIC_KEY=your_public_key
# Get from: accept.paymob.com → Accept → iFrame
VITE_PAYMOB_IFRAME_ID=123456

# ── SUPPORT (REQUIRED) ───────────────────────────────────────
VITE_SUPPORT_EMAIL=support@postureai.io

# ── OPTIONAL ─────────────────────────────────────────────────
VITE_AUTO_APPROVE_DOMAIN=postureai.io
VITE_ADMIN_PHONE=+201234567890
VITE_SHOW_DEMO=false
