# PostureAI Pro — Frontend Environment Variables
# Copy this file to .env.local and fill in your actual values.
# NEVER commit .env.local to git.

# ── Firebase (from Firebase Console → Project Settings → General) ──
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012
VITE_FIREBASE_APP_ID=1:123456789012:web:abcdef1234567890

# ── Backend API ────────────────────────────────────────────────────
# Local dev: http://localhost:5050/api
# Production: https://your-backend.railway.app/api
VITE_API_URL=http://localhost:5050/api

# ── PayMob (from PayMob Dashboard → Settings → Account Info) ──────
# Public key is safe to expose in frontend (used for iframe only)
VITE_PAYMOB_PUBLIC_KEY=egy_pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_PAYMOB_IFRAME_ID=000000

# ── Stripe (from Stripe Dashboard → API Keys → Publishable key) ───
VITE_STRIPE_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Monitoring ────────────────────────────────────────────────────
# From Sentry → Your Project → Settings → Client Keys (DSN)
VITE_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
