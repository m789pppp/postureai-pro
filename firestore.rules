rules_version = '2';

// PostureAI Pro — Firestore Security Rules v3
// SECURITY HARDENED:
//   - Organization isolation: users can only read data within their company
//   - is_admin can only be set by Cloud Functions (not by client writes)
//   - Audit logs are append-only
//   - Payment records are write-once (no client modification)

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper Functions ────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null && request.auth.uid != null;
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isAuthenticated() && getUserData().get('is_admin', false) == true;
    }

    function isHR() {
      return isAuthenticated() && (
        getUserData().get('is_hr', false) == true ||
        getUserData().get('is_admin', false) == true
      );
    }

    function isSameCompany(companyId) {
      return isAuthenticated() && getUserData().get('company_id', null) == companyId;
    }

    function isValidTier(tier) {
      return tier in ['basic', 'professional', 'elite', 'b2b_starter', 'b2b_growth', 'b2b_enterprise'];
    }

    // Prevent client from escalating their own privileges
    function noPrivilegeEscalation() {
      return !request.resource.data.diff(resource.data).affectedKeys()
        .hasAny(['is_admin', 'tier', 'is_hr', 'is_org_owner', 'user_type', 'company_id',
                 'referral_credits', 'referral_count', 'subscription_status',
                 'subscription_expiry', 'payment_method']);
    }

    // Allow trial expiry: owner can write tier ONLY when downgrading from trial
    // (is_trial was true, now being set to false — cannot self-upgrade paid tier)
    function isTrialExpiry() {
      return resource.data.get('is_trial', false) == true
          && request.resource.data.get('is_trial', false) == false
          && !request.resource.data.diff(resource.data).affectedKeys()
               .hasAny(['is_admin', 'is_hr', 'is_org_owner', 'user_type', 'company_id']);
    }

    // ── Users Collection ────────────────────────────────────────
    match /users/{uid} {
      // Read: own profile OR admin OR HR within same company
      allow read: if isOwner(uid)
                  || isAdmin()
                  || (isHR() && isSameCompany(resource.data.get('company_id', '')));

      // Create: own profile on signup
      allow create: if isOwner(uid)
                    && request.resource.data.get('is_admin', false) == false
                    && request.resource.data.get('is_hr', false) == false;

      // Update: own profile but CANNOT self-escalate privileges
      // Admin CAN update any user field (used by AdminDashboard confirmPayment)
      // isTrialExpiry: owner can flip tier during trial → standard (never upgrade)
      allow update: if isAdmin()
                    || (isOwner(uid) && noPrivilegeEscalation())
                    || (isOwner(uid) && isTrialExpiry());

      // Delete: only admin
      allow delete: if isAdmin();
    }

    // ── User Payments Subcollection ─────────────────────────────
    // Written by Admin SDK (webhook) — client can only read their own
    match /users/{uid}/payments/{paymentId} {
      allow read: if isOwner(uid) || isAdmin();
      allow create, update, delete: if false; // Admin SDK only (webhook)
    }

    // ── User AI Insights Subcollection ───────────────────────────
    match /users/{uid}/ai_insights/{insightId} {
      allow read, create, update: if isOwner(uid) || isAdmin();
      allow delete: if isOwner(uid) || isAdmin();
    }

    // ── User Sessions Subcollection (if used) ────────────────────
    match /users/{uid}/sessions/{sessionId} {
      allow read, create: if isOwner(uid) || isAdmin();
      allow update, delete: if isOwner(uid) || isAdmin();
    }

    // ── User Notifications Subcollection ────────────────────────
    match /users/{uid}/notifications/{notifId} {
      allow read, update: if isOwner(uid) || isAdmin();
      allow create, delete: if false; // Admin SDK only (dispatch serverless)
    }

    // ── Sessions Collection ─────────────────────────────────────
    match /sessions/{sessionId} {
      // Read: own sessions OR admin OR HR in same company
      allow read: if isAuthenticated() && (
        resource.data.uid == request.auth.uid
        || isAdmin()
        || (isHR() && resource.data.get('company_id', '') != ''
            && isSameCompany(resource.data.get('company_id', '')))
      );
      // Create: only own sessions (use request.resource for new doc)
      allow create: if isAuthenticated()
                   && request.resource.data.uid == request.auth.uid;
      // Update: only own sessions
      allow update: if isAuthenticated()
                   && resource.data.uid == request.auth.uid;
      allow delete: if isAuthenticated()
                   && resource.data.uid == request.auth.uid;
    }

    // ── Companies Collection ─────────────────────────────────────
    match /companies/{companyId} {
      // Read: own company members OR admin
      allow read: if isAdmin() || isSameCompany(companyId);

      // Create: authenticated users (starting a company)
      allow create: if isAuthenticated();

      // Update: only admin or HR of that company
      allow update: if isAdmin()
                    || (isHR() && isSameCompany(companyId));

      allow delete: if isAdmin();
    }

    // ── Departments Collection ───────────────────────────────────
    match /departments/{deptId} {
      allow read: if isAdmin()
                  || (isAuthenticated()
                      && isSameCompany(resource.data.get('company_id', '')));
      allow create, update: if isAdmin()
                             || (isHR()
                                 && isSameCompany(request.resource.data.get('company_id', '')));
      allow delete: if isAdmin();
    }

    // ── Payments Collection ──────────────────────────────────────
    match /payments/{paymentId} {
      // Read: own payments OR admin
      allow read: if isAuthenticated()
                  && (resource.data.uid == request.auth.uid || isAdmin());

      // Create: client can record pending payment (recordPayment)
      allow create: if isAuthenticated()
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.get('status','') == 'pending';
      // Update: admin only (confirmPayment / rejectPayment)
      allow update: if isAdmin();
      // Delete: never
      allow delete: if false;
    }

    // ── Audit Logs — append-only ─────────────────────────────────
    match /audit_logs/{logId} {
      // Read: admin only
      allow read: if isAdmin();
      // Create: any authenticated user (backend writes these)
      allow create: if isAuthenticated();
      // Update/Delete: NEVER (append-only for compliance)
      allow update, delete: if false;
    }

    // ── Coupons ──────────────────────────────────────────────────
    match /coupons/{code} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    // ── Notifications ────────────────────────────────────────────
    match /notifications/{notifId} {
      allow read, delete: if isAuthenticated()
                          && resource.data.uid == request.auth.uid;
      allow create: if isAuthenticated()
                    && request.resource.data.uid == request.auth.uid;
      allow update: if false;
    }

    // ── API Keys ─────────────────────────────────────────────────
    match /api_keys/{keyId} {
      allow read: if isAuthenticated()
                  && resource.data.uid == request.auth.uid;
      allow create: if isAuthenticated()
                    && request.resource.data.uid == request.auth.uid;
      allow delete: if isAuthenticated()
                    && resource.data.uid == request.auth.uid;
      allow update: if false;
    }

    // ── Webhooks ─────────────────────────────────────────────────
    match /webhooks/{webhookId} {
      allow read, create, update, delete: if isAuthenticated()
                                          && resource.data.uid == request.auth.uid;
      allow create: if isAuthenticated()
                    && request.resource.data.uid == request.auth.uid;
    }

    // ── Invites ──────────────────────────────────────────────────
    match /invites/{inviteId} {
      // SECURITY: previously `allow read: if isAuthenticated()` let ANY signed-in
      // user — from any company — query the entire invites collection, leaking
      // other companies' invited emails, roles, and company_id (cross-tenant
      // data leak). Read is now scoped to: platform admins, the HR admin of the
      // same company as the invite, or the invited user themselves (matched by
      // email, since the invite has no accepter uid until accepted).
      allow read: if isAuthenticated() && (
        getUserData().get('is_admin', false) == true ||
        (getUserData().get('is_hr', false) == true &&
         isSameCompany(resource.data.get('company_id', ''))) ||
        resource.data.get('email', null) == getUserData().get('email', null) ||
        resource.data.get('accepted_by', null) == request.auth.uid
      );
      // SECURITY: isHR() alone only checks is_hr/is_admin — it does NOT verify
      // the invite being created belongs to the HR's own company. Without the
      // isSameCompany() check, any HR admin at Company A could create invite
      // documents with company_id = Company B and effectively recruit/control
      // another company's roster. Platform admins (is_admin) are exempt since
      // they legitimately manage invites across companies.
      allow create: if isAuthenticated() && (
        getUserData().get('is_admin', false) == true ||
        (getUserData().get('is_hr', false) == true &&
         isSameCompany(request.resource.data.company_id))
      );
      // SECURITY: "accepting an invite" must only ever transition status
      // pending -> accepted, stamped with the accepting user's own uid, and
      // must NEVER let the caller change company_id, department, role, or any
      // other field on the invite — those belong to the inviter, not the
      // accepter. The previous rule (`allow update: if isAuthenticated()`)
      // let any signed-in user rewrite ANY field on ANY invite document,
      // including company_id, effectively letting someone reassign an
      // invite to a different company or re-use/tamper with it freely.
      allow update: if isAuthenticated()
                    && resource.data.status == "pending"
                    && request.resource.data.status == "accepted"
                    && request.resource.data.accepted_by == request.auth.uid
                    // every field except status/accepted_by/accepted_at must be unchanged
                    && request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(["status", "accepted_by", "accepted_at"]);
      // SECURITY: same company-match requirement as create — an HR admin must
      // only be able to delete invites belonging to their own company.
      allow delete: if isAuthenticated() && (
        getUserData().get('is_admin', false) == true ||
        (getUserData().get('is_hr', false) == true &&
         isSameCompany(resource.data.get('company_id', '')))
      );
    }

    // ── Linked Accounts ──────────────────────────────────────────
    // Format: {primaryUid}__{linkedUid}
    // Only the primary account owner can read/write their linked accounts
    match /linked_accounts/{linkId} {
      allow read: if isAuthenticated()
                  && resource.data.primary_uid == request.auth.uid;
      allow create: if isAuthenticated()
                    && request.resource.data.primary_uid == request.auth.uid
                    && request.resource.data.primary_uid != request.resource.data.linked_uid;
      allow delete: if isAuthenticated()
                    && resource.data.primary_uid == request.auth.uid;
      allow update: if false; // immutable — delete and recreate
    }

    // ── Shared Reports (Phase 3) ──────────────────────────────────
    // Public read (anyone with token can read) — no login required
    // Write: owner only (server-side via App or firebase.js)
    // Expiry enforced client-side + Cloud Function (future)
    match /shared_reports/{reportId} {
      // Anyone can read (public shareable link — no auth required)
      allow read: if true;
      // Only the authenticated owner can create/update their own report
      allow create: if isAuthenticated()
                    && request.resource.data.owner_uid == request.auth.uid
                    && request.resource.data.expires_at is timestamp;
      // Allow owner to increment view_count only
      allow update: if (
        // Unauthenticated view count increment (fire-and-forget)
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(["view_count"])
      ) || (
        isAuthenticated() && resource.data.owner_uid == request.auth.uid
      );
      allow delete: if isAuthenticated()
                    && resource.data.owner_uid == request.auth.uid;
    }

    // ── EMR Webhooks (Phase 3) ────────────────────────────────────
    // Write-only from backend (no client reads)
    match /emr_webhooks/{webhookId} {
      allow read: if isAuthenticated()
                  && request.auth.token.admin == true;
      allow create: if false; // backend only via Admin SDK
      allow update, delete: if false;
    }

    // ── Notification Logs (server-written audit trail) ──────────
    match /notification_logs/{logId} {
      allow read: if isAdmin();
      allow create, update, delete: if false; // Admin SDK only
    }

    // ── Org Notifications (broadcast) ────────────────────────────
    match /orgs/{orgId}/notifications/{notifId} {
      allow read: if isAuthenticated() && (isAdmin() || isHR());
      allow update: if isAuthenticated(); // mark as read
      allow create, delete: if false; // Admin SDK only
    }

    // ── Deny everything else ─────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
