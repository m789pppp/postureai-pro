# ============================================================
# PostureAI Pro — Backend Environment Variables
# Add ALL of these to Railway → Your Service → Variables
# ============================================================

# ── FIREBASE ADMIN (REQUIRED) ────────────────────────────────
# Get from: console.firebase.google.com → Project Settings → Service Accounts
# → Generate New Private Key → download JSON → copy values below
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIEow...\n-----END RSA PRIVATE KEY-----\n"

# ── GEMINI AI (REQUIRED) ─────────────────────────────────────
# Get from: aistudio.google.com → Get API Key
GEMINI_API_KEY=AIzaSy...

# ── STRIPE (REQUIRED) ────────────────────────────────────────
# Get from: dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=sk_live_...
# Get from: Stripe → Developers → Webhooks → Add endpoint → Signing secret
# Endpoint URL: https://your-backend.railway.app/api/stripe/webhook
# Events: checkout.session.completed, customer.subscription.updated,
#         customer.subscription.deleted, invoice.paid, invoice.payment_failed
STRIPE_WEBHOOK_SECRET=whsec_...

# ── PAYMOB (REQUIRED for Egypt) ──────────────────────────────
# Get from: accept.paymob.com → Settings → Account Info
PAYMOB_SECRET_KEY=your_secret_key
PAYMOB_HMAC_SECRET=your_hmac_secret
# Get from: accept.paymob.com → Accept → Payment Integrations
PAYMOB_INTEGRATION_CARD=123456
PAYMOB_INTEGRATION_WALLET=123456

# ── EMAIL / SENDGRID (REQUIRED) ──────────────────────────────
# Get from: app.sendgrid.com → Settings → API Keys → Create API Key (Full Access)
# IMPORTANT: Also verify your sender domain in SendGrid → Settings → Sender Authentication
SENDGRID_API_KEY=SG.xxx...
SUPPORT_EMAIL=support@postureai.io

# ── APP CONFIG (REQUIRED) ────────────────────────────────────
FLASK_ENV=production
APP_URL=https://postureai-pro-omega-nine.vercel.app
ALLOWED_ORIGINS=https://postureai-pro-omega-nine.vercel.app

# ── REDIS (RECOMMENDED) ──────────────────────────────────────
# Get from: upstash.com → Create Database (free tier) → Redis URL
# Needed for: rate limiting, caching, Celery tasks
REDIS_URL=redis://default:password@host:port

# ── ADMIN CONFIG (OPTIONAL) ──────────────────────────────────
ADMIN_EMAIL=admin@postureai.io
ADMIN_PHONE=+201234567890

# ── MONITORING (OPTIONAL) ────────────────────────────────────
# Get from: sentry.io → Your Project → Settings → Client Keys → DSN
SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# ── NOTIFICATIONS (OPTIONAL) ─────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/xxx/xxx
TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/xxx

# ── WHATSAPP (OPTIONAL) ──────────────────────────────────────
# Get from: developers.facebook.com → WhatsApp → API Setup
WA_ACCESS_TOKEN=EAAxxxxxxx
WA_PHONE_NUMBER_ID=123456789

# ── ENTERPRISE SSO (OPTIONAL) ────────────────────────────────
# Auto-generated: openssl rand -hex 32
SCIM_BEARER_TOKEN=your_64_char_random_secret

# ── WORK HOURS (OPTIONAL) ────────────────────────────────────
WORK_HOURS_START=9
WORK_HOURS_END=17

# ── ADVANCED (OPTIONAL) ──────────────────────────────────────
CELERY_ENABLED=false
SOCKETIO_ENABLED=false
MAX_CONTENT_LENGTH=10485760
