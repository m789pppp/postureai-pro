# PostureAI Pro — Backend Environment Variables
# Copy to .env for local development. Use Railway/Render panel for production.

# ── Flask ──────────────────────────────────────────────────────────
FLASK_ENV=development
PORT=5050
SECRET_KEY=CHANGE-ME-use-python-secrets-token-hex-32
LOG_LEVEL=info

# ── Firebase Admin SDK ─────────────────────────────────────────────
# Option A: JSON string (recommended for Railway/Render)
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
# Option B: File path (local dev)
# Place file at backend/firebase-service-account.json

# ── Redis (REQUIRED in production) ────────────────────────────────
REDIS_URL=redis://localhost:6379/0
# Railway: auto-injected as $REDIS_URL when Redis addon is added

# ── CORS ───────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,https://app.postureai.io

# ── Gemini AI (Google) ────────────────────────────────────────────
GEMINI_API_KEY=AIzaSy...

# ── PayMob (EGP payments) ─────────────────────────────────────────
PAYMOB_API_KEY=ZXlKaGJHY...
PAYMOB_INTEGRATION_ID=000000
PAYMOB_HMAC_SECRET=your-paymob-hmac-secret
PAYMOB_IFRAME_ID=000000

# ── Stripe (USD payments) ─────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Stripe Price IDs (from Stripe Dashboard)
STRIPE_PRICE_STD_MONTHLY=price_xxx
STRIPE_PRICE_STD_YEARLY=price_xxx
STRIPE_PRICE_PRO_MONTHLY=price_xxx
STRIPE_PRICE_PRO_YEARLY=price_xxx
STRIPE_PRICE_ELITE_MONTHLY=price_xxx
STRIPE_PRICE_ELITE_YEARLY=price_xxx

# ── Email (use SendGrid in production, NOT Gmail) ──────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=SG.your-sendgrid-api-key
SMTP_FROM=noreply@postureai.io

# ── App URLs ───────────────────────────────────────────────────────
APP_URL=https://app.postureai.io
BACKEND_URL=https://api.postureai.io

# ── Sentry Monitoring ─────────────────────────────────────────────
SENTRY_DSN=https://...@sentry.io/project-id

# ── Celery (async analysis) ───────────────────────────────────────
CELERY_ENABLED=false
# Set to true and start celery worker: celery -A services.celery_app worker

# ── MFA — TOTP + SMS ──────────────────────────────────────────────
# pyotp handles TOTP with no env vars needed
# Twilio for SMS MFA (optional — skip to use TOTP-only)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# ── SendGrid (recommended over Gmail for production) ──────────────
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── SCIM 2.0 (Okta / Azure AD / JumpCloud provisioning) ──────────
# Generate a strong random token: python3 -c "import secrets; print(secrets.token_urlsafe(40))"
SCIM_BEARER_TOKEN=your-strong-random-scim-token-here

# ── SSO / OIDC ────────────────────────────────────────────────────
# Configured per-org via /api/auth/sso/config endpoint (HR admin)
# No additional env vars needed — Firebase Auth handles OIDC providers
# ── WebSocket real-time analysis (optional) ──────────────────────
# Set true to enable Socket.IO push-based posture updates (replaces polling)
# Requires: pip install flask-socketio gevent gevent-websocket
SOCKETIO_ENABLED=false

# ── Stripe Metered Billing (usage-based overage charges) ─────────
# Create metered prices in Stripe Dashboard → Products
STRIPE_METER_FRAMES=price_xxx   # Per analysis frame over quota
STRIPE_METER_AI=price_xxx       # Per AI report over quota
STRIPE_METER_API=price_xxx      # Per API call over quota
STRIPE_METER_SEATS=price_xxx    # Per seat over plan limit

# ── Cloudflare (WAF + CDN) ────────────────────────────────────────
# Import cloudflare.json in Cloudflare Dashboard → Security → WAF
# No env vars needed — configured directly in Cloudflare dashboard
